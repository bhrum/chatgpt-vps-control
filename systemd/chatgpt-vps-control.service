[Unit]
Description=ChatGPT Oracle VPS MCP control server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/chatgpt-vps-control
EnvironmentFile=/home/ubuntu/chatgpt-vps-control/.env
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
